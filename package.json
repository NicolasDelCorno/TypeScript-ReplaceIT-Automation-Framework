{
  "name": "replaceit-tests-ts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:web": "playwright test",
    "test:web:headed": "playwright test --headed",
    "test:web:ci": "playwright test --project=chromium",
    "test:mobile:ios": "PLATFORM=ios wdio run mobile/wdio.config.ts",
    "test:mobile:android": "PLATFORM=android wdio run mobile/wdio.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@wdio/appium-service": "^9.4.0",
    "@wdio/cli": "^9.4.0",
    "@wdio/globals": "^9.4.0",
    "@wdio/local-runner": "^9.4.0",
    "@wdio/mocha-framework": "^9.4.0",
    "@wdio/spec-reporter": "^9.4.0",
    "appium": "^2.11.0",
    "dotenv": "^16.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "webdriverio": "^9.4.0"
  }
}
